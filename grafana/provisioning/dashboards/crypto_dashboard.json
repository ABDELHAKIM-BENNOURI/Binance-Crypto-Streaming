          }
        }
      },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 10 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["last"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "area" },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "questdb-uid" },
          "format": "time_series",
          "rawSql": "SELECT timestamp AS time, price FROM trades WHERE symbol = 'BTCUSDT' ORDER BY timestamp DESC LIMIT 1",
          "refId": "BTC_LAST"
        }
      ],
      "title": "₿ BTC/USDT — Dernier Prix",
      "type": "stat"
    },
    {
      "datasource": { "type": "postgres", "uid": "questdb-uid" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
