          "refId": "BTC_BUY"
        },
        {
          "datasource": {
            "type": "postgres",
            "uid": "questdb-uid"
          },
          "format": "time_series",
          "rawSql": "SELECT timestamp AS time, sum(quantity) * -1 AS \"Volume Vendeur\" FROM trades WHERE symbol = 'BTCUSDT' AND is_buyer_maker = 0 AND $__timeFilter(timestamp) SAMPLE BY 1m",
          "refId": "BTC_SELL"
        }
      ],
      "title": "⚖️ Pression Acheteur / Vendeur — BTC (Signal de Tendance)",
