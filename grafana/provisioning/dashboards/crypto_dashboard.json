      "description": "",
      "type": "datasource",
      "pluginId": "postgres",
      "pluginName": "PostgreSQL"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "8.0.0" },
    { "type": "datasource", "id": "postgres", "name": "PostgreSQL", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": true,
  "panels": [
    {
      "datasource": { "type": "postgres", "uid": "questdb-uid" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "currencyUSD",
          "decimals": 2
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "BTCUSDT" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#F7931A", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "ETHUSDT" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#627EEA", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "legend": { "calcs": ["last", "min", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "questdb-uid" },
          "format": "time_series",
          "rawSql": "SELECT timestamp AS time, price, symbol FROM trades WHERE symbol = 'BTCUSDT' AND $__timeFilter(timestamp) ORDER BY timestamp",
          "refId": "BTC"
        },
        {
          "datasource": { "type": "postgres", "uid": "questdb-uid" },
          "format": "time_series",
          "rawSql": "SELECT timestamp AS time, price, symbol FROM trades WHERE symbol = 'ETHUSDT' AND $__timeFilter(timestamp) ORDER BY timestamp",
          "refId": "ETH"
