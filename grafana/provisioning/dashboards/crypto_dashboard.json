          "datasource": { "type": "postgres", "uid": "questdb-uid" },
          "format": "time_series",
          "rawSql": "SELECT timestamp AS time, count(*) AS trades_count FROM trades WHERE $__timeFilter(timestamp) SAMPLE BY 1m",
          "refId": "COUNT"
