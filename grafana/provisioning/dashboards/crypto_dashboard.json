    {
      "datasource": {
        "type": "postgres",
        "uid": "questdb-uid"
      },
      "description": "⚖️ PRESSION ACHETEUR vs VENDEUR (BTC) — Mesure le volume total acheté (valeurs positives, vert) vs le volume total vendu (valeurs négatives, rouge) par minute. Si la pression vendeuse domine et s'accélère, c'est un signal de risque de baisse de prix. À l'inverse, une pression acheteuse forte suggère une tendance haussière.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 30
          },
          "unit": "short",
          "decimals": 4
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Volume Acheteur"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#73BF69",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Volume Vendeur"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#F2495C",
                  "mode": "fixed"
                }
              }
