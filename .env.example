# Copier ce fichier en .env et remplir les valeurs
# cp .env.example .env

# Binance WebSocket — URL du flux temps réel (ex: btcusdt@trade/ethusdt@trade)
BINANCE_WS_URL=

# Kafka — Adresse du broker (ex: localhost:9092)
KAFKA_BROKER=

# Kafka — Préfixe des topics (ex: crypto_trades_)
KAFKA_TOPIC_PREFIX=
